# =============================================================================
# Open Mandi — Environment Variables
# Copy this file to .env.local and fill in your values.
# Or run `vercel env pull .env.local` to pull from Vercel.
# =============================================================================

# -----------------------------------------------------------------------------
# Firebase Client (NEXT_PUBLIC_ = exposed to browser)
# Get these from: Firebase Console → Project Settings → General → Your apps
# -----------------------------------------------------------------------------
NEXT_PUBLIC_FIREBASE_API_KEY=
NEXT_PUBLIC_FIREBASE_AUTH_DOMAIN=
NEXT_PUBLIC_FIREBASE_PROJECT_ID=

# -----------------------------------------------------------------------------
# Firebase Admin (server-only, never exposed to browser)
# Get these from: Firebase Console → Project Settings → Service Accounts
# → Generate New Private Key (download JSON, extract values)
# -----------------------------------------------------------------------------
FIREBASE_PROJECT_ID=
FIREBASE_CLIENT_EMAIL=
FIREBASE_PRIVATE_KEY=

# -----------------------------------------------------------------------------
# Vercel Postgres (Neon)
# Auto-set by Vercel when you add a Postgres store.
# Locally: run `vercel env pull .env.local` or copy from Neon dashboard.
# Only these 2 are used by the app — other Neon vars are optional aliases.
# -----------------------------------------------------------------------------
POSTGRES_URL=
POSTGRES_URL_NON_POOLING=

# -----------------------------------------------------------------------------
# Metals Price API (gold/silver index prices)
# Free tier: 100 requests/month — register at https://metals.dev
# Falls back to hardcoded prices ($2850 gold, $32 silver) if missing.
# -----------------------------------------------------------------------------
METALS_DEV_API_KEY=

# -----------------------------------------------------------------------------
# On-Chain / Ethereum
# ETH_RPC_URL          — Alchemy / Infura JSON-RPC endpoint
# ETH_USDC_CONTRACT    — USDC token contract address
# ETH_NETWORK          — "sepolia" or "mainnet" (controls Etherscan links)
# EXCHANGE_DEPOSIT_ADDRESS_USDC — Shared deposit address (legacy, pre-HD)
# DEPOSIT_HD_MNEMONIC  — BIP-44 mnemonic for per-user deposit addresses
# HOT_WALLET_PRIVATE_KEY — Private key of the exchange hot wallet (for
#                          sending on-chain withdrawals). Export from MetaMask.
# -----------------------------------------------------------------------------
ETH_RPC_URL=
ETH_USDC_CONTRACT=
ETH_NETWORK=sepolia
EXCHANGE_DEPOSIT_ADDRESS_USDC=
DEPOSIT_HD_MNEMONIC=
HOT_WALLET_PRIVATE_KEY=
